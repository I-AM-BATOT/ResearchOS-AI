# ResearchOS AI - environment configuration
# Copy this file to .env and fill in real values.
# The app runs fully in MOCK mode with NO values set (offline demo mode).

# --- LLM (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- MCP server ---
MCP_HOST=0.0.0.0
MCP_PORT=8765

# --- Memory ---
MEMORY_DIR=./.researchos_memory
CHROMA_COLLECTION=researchos_memory

# --- Limits ---
MAX_PDF_MB=25

# --- Logging ---
LOG_LEVEL=INFO

# --- Testing / CI ---
# Set to true to force mock mode even if GEMINI_API_KEY is set (useful for CI)
FORCE_MOCK_MODE=false
